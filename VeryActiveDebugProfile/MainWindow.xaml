<Window x:Class="VeryActiveDebugProfile.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VeryActiveDebugProfile"
        mc:Ignorable="d"
        Title="Very ActiveDebugProfile" Height="450" Width="800">
    <Grid RowDefinitions="Auto, Auto, *" Background="{DynamicResource MyGridBackgroundBrush}">
        <Label Grid.Row="0" 
               x:Name="StatusLabel" 
               Content="{Binding DeviceStatusText}" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center" 
               FontSize="16">
            <Label.Style>
                <Style TargetType="Label">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDeviceConnected}" Value="True">
                            <Setter Property="Foreground" Value="Green"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDeviceConnected}" Value="False">
                            <Setter Property="Foreground" Value="Red"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Label.Style>
        </Label>
        <Button Grid.Row="1" x:Name="RefreshButton" Content="Force Update" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" Padding="10,5" Command="{Binding RefreshCommand}"/>

        <DataGrid x:Name="LogGrid"
            ItemsSource="{Binding LogEntries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True" 
                  Grid.Row="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"
                            Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                <DataGridTextColumn Header="Message"
                            Binding="{Binding Message}" 
                            Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
